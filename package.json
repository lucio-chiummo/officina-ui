{
  "name": "officina-ui-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm docs:props && pnpm --filter @officina/ui build && pnpm --filter @officina/docs build",
    "build:ui": "pnpm --filter @officina/ui build",
    "build:docs": "pnpm --filter @officina/docs build",
    "dev:docs": "pnpm --filter @officina/ui build && pnpm docs:props && pnpm --filter @officina/docs dev",
    "docs:props": "tsx scripts/generate-component-docs.ts",
    "drift:generate": "tsx scripts/generate-drift-manifest.ts",
    "drift:check": "tsx scripts/generate-drift-manifest.ts && git diff --exit-code drift-manifest.json || (echo 'drift-manifest.json is out of date — run: pnpm drift:generate and commit the result' && exit 1)",
    "drift:compare": "tsx scripts/compare-drift-manifests.ts",
    "typecheck": "pnpm --filter @officina/ui typecheck",
    "test": "pnpm --filter @officina/ui test",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "version:packages": "changeset version",
    "release": "pnpm build:ui && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@eslint/js": "^9.16.0",
    "eslint": "^9.16.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-perfectionist": "^4.2.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-tailwindcss": "^3.17.0",
    "glob": "^13.0.6",
    "globals": "^15.13.0",
    "prettier": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "react-docgen-typescript": "^2.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.17.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
